{
  "name": "tweet-accountability-archive",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "db:migrate:run": "npm run db:migrate:run --workspace=@taa/db",
    "db:seed": "npm run db:seed --workspace=@taa/db",
    "test": "turbo run test"
  },
  "packageManager": "npm@11.6.2",
  "devDependencies": {
    "@types/node-cron": "^3.0.11",
    "playwright": "^1.58.2",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@hiero-ledger/proto": "^2.25.0",
    "node-cron": "^4.2.1"
  }
}
