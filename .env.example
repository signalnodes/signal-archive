# copy to .env and fill in
# never commit .env

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tweet_accountability

# Redis
REDIS_URL=redis://localhost:6379

# Hedera
HEDERA_OPERATOR_ID=
HEDERA_OPERATOR_KEY=
HEDERA_NETWORK=testnet

# HCS Topic ID (created via scripts/create-hcs-topic.ts)
HEDERA_TOPIC_ID=

# SocialData.tools API (primary ingestion & deletion detection)
SOCIALDATA_API_KEY=

# Stagehand / Browser Automation (legacy fallback — only needed if SOCIALDATA_API_KEY is not set)
STAGEHAND_ENV=LOCAL
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
ANTHROPIC_API_KEY=

# Ingestion
MOCK_INGESTION=false
# Only archive tweets posted on or after this date (ISO 8601). Default: 2025-01-01.
ARCHIVE_SINCE=2025-01-01T00:00:00Z
