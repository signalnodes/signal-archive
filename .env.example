# copy to .env and fill in
# never commit .env

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tweet_accountability

# Redis
REDIS_URL=redis://localhost:6379

# Hedera
HEDERA_OPERATOR_ID=
HEDERA_OPERATOR_KEY=
HEDERA_NETWORK=testnet

# HCS Topic IDs
HEDERA_TOPIC_ID=                    # public tweet attestations (0.0.10301350 on mainnet)
HEDERA_RESEARCH_TOPIC_ID=           # research: wallet & account flagging (0.0.10307943 on mainnet)
HEDERA_DONATION_TOPIC_ID=           # donation receipts — run scripts/create-donation-topic.ts

# SocialData.tools API — required for tweet ingestion; optional for deletion detection
# (oEmbed fallback is used for deletion checks when this key is absent)
SOCIALDATA_API_KEY=

# Stagehand / Browser Automation (legacy fallback — only needed if SOCIALDATA_API_KEY is not set)
STAGEHAND_ENV=LOCAL
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# AI Severity Scoring: Claude Haiku scores each deletion 1-10 for public interest significance
# Get key at console.anthropic.com. Falls back to heuristic scoring if not set.
ANTHROPIC_API_KEY=
AI_SCORING_ENABLED=true

# Wallet Connect / Donations
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_HEDERA_NETWORK=mainnet
NEXT_PUBLIC_DONATION_ACCOUNT_ID=
NEXT_PUBLIC_USDC_TOKEN_ID=0.0.456858
NEXT_PUBLIC_BADGE_TOKEN_ID=         # supporter NFT badge — run scripts/create-badge-token.ts
BADGE_IMAGE_CID=                    # IPFS CID of badge PNG — set after art is pinned; used by /api/nft/[serial]
NEXT_PUBLIC_APP_URL=https://signalarchive.org

# Worker health monitoring (Better Stack heartbeat URL — optional)
# Create a heartbeat monitor at betterstack.com and paste the ping URL here
HEARTBEAT_URL=

# Ingest watchdog push notifications via ntfy.sh (optional)
# Pick any unique topic name, subscribe at https://ntfy.sh/<topic> or the ntfy mobile app
NTFY_TOPIC=

# Ingestion
MOCK_INGESTION=false
# Only archive tweets posted on or after this date (ISO 8601). Default: 2025-01-01.
ARCHIVE_SINCE=2025-01-01T00:00:00Z

# ── VPS / Docker (deploy/docker-compose.yml) ───────────────────────────────────
# These vars are used when running the stack on VPS via Docker Compose.
# Not needed for local development.

# Chrome CDP endpoint — points to chrome container in Docker, or local Chrome for --cdp mode
# Docker:  CDP_URL=http://chrome:9223
# Local:   CDP_URL=http://localhost:9222  (auto-detected; this var is optional locally)
CDP_URL=http://chrome:9223

# SOCKS5 proxy for residential egress (Chrome container only).
# Run microsocks on the home node bound to its Tailscale interface, then set this to:
#   socks5://<home-tailscale-ip>:1080
# Chrome connects through this for all twitter.com traffic.
# Worker, Redis, and API traffic (Neon/Hedera/Anthropic) go direct from VPS — no proxy.
SOCKS5_PROXY_URL=socks5://100.x.x.x:1080

# Redis URL — VPS Docker uses redis://redis:6379 (service name in compose network)
# Local dev uses redis://localhost:6379 (defined above)
