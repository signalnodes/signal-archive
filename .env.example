# copy to .env and fill in
# never commit .env

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tweet_accountability

# Redis
REDIS_URL=redis://localhost:6379

# Hedera
HEDERA_OPERATOR_ID=
HEDERA_OPERATOR_KEY=
HEDERA_NETWORK=testnet

# HCS Topic IDs (created via Hedera SDK)
HEDERA_TOPIC_ID=
HCS_TOPIC_TRUMP_FAMILY=
HCS_TOPIC_CONGRESS=
HCS_TOPIC_AGENCIES=
HCS_TOPIC_CRYPTO=

# Stagehand / Browser Automation
STAGEHAND_ENV=LOCAL
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# Ingestion
MOCK_INGESTION=false
ANTHROPIC_API_KEY=
