# copy to .env and fill in
# never commit .env

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tweet_accountability

# Redis
REDIS_URL=redis://localhost:6379

# Hedera
HEDERA_OPERATOR_ID=
HEDERA_OPERATOR_KEY=
HEDERA_NETWORK=testnet

# HCS Topic IDs
HEDERA_TOPIC_ID=                    # public tweet attestations (0.0.10301350 on mainnet)
HEDERA_RESEARCH_TOPIC_ID=           # research: wallet & account flagging (0.0.10307943 on mainnet)
HEDERA_DONATION_TOPIC_ID=           # donation receipts — run scripts/create-donation-topic.ts

# SocialData.tools API (primary ingestion & deletion detection)
SOCIALDATA_API_KEY=

# Stagehand / Browser Automation (legacy fallback — only needed if SOCIALDATA_API_KEY is not set)
STAGEHAND_ENV=LOCAL
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
ANTHROPIC_API_KEY=

# Wallet Connect / Donations
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_HEDERA_NETWORK=mainnet
NEXT_PUBLIC_DONATION_ACCOUNT_ID=
NEXT_PUBLIC_USDC_TOKEN_ID=0.0.456858
NEXT_PUBLIC_BADGE_TOKEN_ID=         # supporter NFT badge — run scripts/create-badge-token.ts
BADGE_IMAGE_CID=                    # IPFS CID of badge PNG — set after art is pinned; used by /api/nft/[serial]
NEXT_PUBLIC_APP_URL=https://signalarchive.org

# Worker health monitoring (Better Stack heartbeat URL — optional)
# Create a heartbeat monitor at betterstack.com and paste the ping URL here
HEARTBEAT_URL=

# Ingestion
MOCK_INGESTION=false
# Only archive tweets posted on or after this date (ISO 8601). Default: 2025-01-01.
ARCHIVE_SINCE=2025-01-01T00:00:00Z
